generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         String   @default("HR")
  createdAt    DateTime @default(now())
}

model Vacancy {
  id           String      @id @default(cuid())
  name         String
  description  String?
  requirements String?     // JSON string of requirements/competencies
  candidates   Candidate[]
  sessions     Session[]
  createdAt    DateTime    @default(now())
}

model Candidate {
  id        String    @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  vacancyId String?
  vacancy   Vacancy?  @relation(fields: [vacancyId], references: [id], onDelete: SetNull)
  sessions  Session[]
  createdAt DateTime  @default(now())
}

model Session {
  id          String     @id @default(cuid())
  candidateId String
  candidate   Candidate  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  vacancyId   String?
  vacancy     Vacancy?   @relation(fields: [vacancyId], references: [id], onDelete: SetNull)
  inviteCode  String     @unique
  testIds     String     @default("[]") // JSON string of test IDs selected for this session
  status      String     @default("PENDING") // PENDING, STARTED, COMPLETED
  startedAt   DateTime?
  completedAt DateTime?
  responses   Response[]
  scores      Score[]
  hrNotes     HRNote?
}

model Test {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  description String
  order       Int        @default(0)
  isCustom    Boolean    @default(false)
  createdBy   String?    // User ID
  questions   Question[]
}

model Question {
  id           String     @id @default(cuid())
  testId       String
  test         Test       @relation(fields: [testId], references: [id], onDelete: Cascade)
  text         String
  type         String     @default("LIKERT") // LIKERT, CHOICE, TEXT
  options      String     @default("[]") // JSON string of options
  reverseKey   Boolean    @default(false)
  scaleWeights String     @default("{}") // JSON string: { "ScaleName": weight }
  responses    Response[]
}

model Response {
  id         String   @id @default(cuid())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  testId     String
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answer     String
  answeredAt DateTime @default(now())
}

model Score {
  id         String   @id @default(cuid())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  testId     String
  results    String   @default("{}") // JSON string of computed scales
  computedAt DateTime @default(now())
}

model HRNote {
  id        String   @id @default(cuid())
  sessionId String   @unique
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  decision  String?  // RECOMMENDED, CONDITIONAL, NOT_RECOMMENDED
  notes     String?
  tags      String   @default("[]") // JSON string of tags
  updatedAt DateTime @updatedAt
}
